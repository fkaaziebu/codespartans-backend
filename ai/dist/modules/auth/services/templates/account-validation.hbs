<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your Account</title>
  </head>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.5; color: #333; max-width: 480px; margin: 0 auto; padding: 40px 20px;">
    <h2 style="margin: 0 0 24px 0; font-weight: 600;">Verify your account</h2>

    <p style="margin: 0 0 16px 0;">Hi {{name}},</p>

    <p style="margin: 0 0 24px 0;">Use the code below to verify your account. This code expires in 24 hours.</p>

    <div style="display: inline-block; padding: 20px 32px; background-color: #f3f4f6; border-radius: 8px; margin-bottom: 24px;">
      <span style="font-size: 32px; font-weight: 700; letter-spacing: 8px; color: #111827;">{{validationCode}}</span>
    </div>

    <p style="margin: 0 0 8px 0; font-size: 14px; color: #666;">Enter this code on the verification page to activate your account.</p>

    <p style="margin: 0; font-size: 14px; color: #666;">If you didn't create an account, you can ignore this email.</p>
  </body>
</html>
