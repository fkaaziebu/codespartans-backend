<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Demo Lead</title>
  </head>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 40px 20px;">
    <h2 style="margin: 0 0 8px 0; font-weight: 700; color: #111827;">New demo lead — {{lead_type}}</h2>

    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280; width: 40%;">Full name</td>
        <td style="padding: 10px 0; font-size: 14px; font-weight: 500;">{{full_name}}</td>
      </tr>
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">Email</td>
        <td style="padding: 10px 0; font-size: 14px;"><a href="mailto:{{email}}" style="color: #111827;">{{email}}</a></td>
      </tr>
      <tr>
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">Target exam(s)</td>
        <td style="padding: 10px 0; font-size: 14px;">{{target_exams_display}}</td>
      </tr>
    </table>

    <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 0;" />
    <p style="margin: 16px 0 0 0; font-size: 12px; color: #9CA3AF;">This is an automated internal notification from Codespartans.</p>
  </body>
</html>
