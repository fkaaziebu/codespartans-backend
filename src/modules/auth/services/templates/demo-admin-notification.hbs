<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Demo Request</title>
  </head>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 40px 20px;">
    <h2 style="margin: 0 0 8px 0; font-weight: 700; color: #111827;">New demo request</h2>
    <p style="margin: 0 0 24px 0; font-size: 14px; color: #6B7280;">This demo has been automatically approved and the registration link has been sent to the contact.</p>

    <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280; width: 40%;">Contact name</td>
        <td style="padding: 10px 0; font-size: 14px; font-weight: 500;">{{name}}</td>
      </tr>
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">School / Centre</td>
        <td style="padding: 10px 0; font-size: 14px; font-weight: 500;">{{school_name}}</td>
      </tr>
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">Role</td>
        <td style="padding: 10px 0; font-size: 14px;">{{role}}</td>
      </tr>
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">Approx. students</td>
        <td style="padding: 10px 0; font-size: 14px;">{{approximate_students}}</td>
      </tr>
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">Email</td>
        <td style="padding: 10px 0; font-size: 14px;"><a href="mailto:{{email}}" style="color: #111827;">{{email}}</a></td>
      </tr>
      <tr style="border-bottom: 1px solid #e5e7eb;">
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">WhatsApp</td>
        <td style="padding: 10px 0; font-size: 14px;">{{whatsapp_number}}</td>
      </tr>
      <tr>
        <td style="padding: 10px 0; font-size: 13px; color: #6B7280;">Trial duration</td>
        <td style="padding: 10px 0; font-size: 14px;">{{trial_duration_days}} days</td>
      </tr>
    </table>

    <p style="margin: 0 0 8px 0; font-size: 13px; color: #6B7280;">Registration link sent to contact:</p>
    <p style="margin: 0 0 24px 0; font-size: 13px; color: #4B5563; word-break: break-all;">{{registrationUrl}}</p>

    <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 0;" />
    <p style="margin: 16px 0 0 0; font-size: 12px; color: #9CA3AF;">This is an automated internal notification from Codespartans.</p>
  </body>
</html>
